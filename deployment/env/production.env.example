# =============================================================================
# deployment/env/production.env.example
# -----------------------------------------------------------------------------
# TEMPLATE production environment file for the Personalized Search Ranking
# System on EC2. This file is TRACKED IN GIT on purpose (it is a template with
# safe defaults only). It contains NO secrets, NO API keys, NO AWS credentials,
# and NO machine-specific absolute paths.
#
#   On the instance:
#     sudo cp deployment/env/production.env.example /etc/search-ranking/search.env
#     sudo chown root:searchapp /etc/search-ranking/search.env
#     sudo chmod 640 /etc/search-ranking/search.env
#
#   Both systemd units (search-api, search-frontend) load the copied file via
#   `EnvironmentFile=/etc/search-ranking/search.env`. The backend reads every
#   SEARCH_* var through pydantic-settings (env_prefix="SEARCH_"); the Streamlit
#   frontend reads SEARCH_API_URL. Values below mirror the defaults in
#   api/config/settings.py, so leaving them as-is reproduces stock behavior.
#   The ONE value you must keep overridden for EC2 is SEARCH_HOST=0.0.0.0.
# =============================================================================

# ---- Service identity & environment -----------------------------------------
# environment: development | staging | production (validated by settings.py).
SEARCH_ENVIRONMENT=production
# Human-readable service name and version (surfaced in /health and logs).
SEARCH_APP_NAME=Personalized Search Ranking API
SEARCH_APP_VERSION=6.0.0
# Optional URL path prefix for the API (e.g. /api/v1). Empty = mount at root.
# nginx already strips its own /api/ prefix, so leave this empty.
SEARCH_API_PREFIX=

# ---- Server binding ----------------------------------------------------------
# MUST be 0.0.0.0 so uvicorn accepts connections from nginx / other processes.
# (The default in settings.py is 127.0.0.1, which nginx could not reach.)
SEARCH_HOST=0.0.0.0
# API listen port. Matches search-api.service (uvicorn --port 8000) and the
# nginx upstreams (/api/ and /healthz -> 127.0.0.1:8000). Keep in sync if changed.
SEARCH_PORT=8000

# ---- Retrieval / ranking knobs (Week 3-5 defaults; leave as-is) --------------
SEARCH_DEFAULT_TOP_K=10
SEARCH_MAX_TOP_K=100
SEARCH_CANDIDATE_POOL_SIZE=100
SEARCH_CANDIDATE_DEPTH=50
SEARCH_HYBRID_ALPHA=0.4
SEARCH_HYBRID_BETA=0.6
SEARCH_EMBEDDING_BATCH_SIZE=64
SEARCH_CROSS_ENCODER_BATCH_SIZE=32
SEARCH_CROSS_ENCODER_MAX_CHARS=400
# Inference device: cpu | cuda. EC2 target has no GPU -> cpu.
SEARCH_DEVICE=cpu
# BM25 -> 0..1 confidence saturation constant (score/(score+k)). Larger k lowers
# the confidence a given raw score maps to. Leave at the tuned default.
SEARCH_BM25_CONFIDENCE_SATURATION=8.0

# ---- Validation limits -------------------------------------------------------
SEARCH_MIN_QUERY_LENGTH=1
SEARCH_MAX_QUERY_LENGTH=256

# ---- Query cache -------------------------------------------------------------
SEARCH_CACHE_ENABLED=true
SEARCH_CACHE_MAX_SIZE=512
SEARCH_CACHE_TTL_SECONDS=300

# ---- Model / data / cache paths (relative to the repo root) ------------------
SEARCH_DATA_PATH=data/processed/sample_esci_50k.parquet
SEARCH_MODELS_DIR=models
SEARCH_RESULTS_DIR=results
SEARCH_LTR_MODEL_PATH=models/ltr_lightgbm.txt
# Local cross-encoder dir (preferred, offline-safe); hub name is the fallback
# used only if the local dir is absent.
SEARCH_CROSS_ENCODER_DIR=models/ms-marco-MiniLM-L-6-v2
SEARCH_CROSS_ENCODER_HUB_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
# Embedding model is loaded BY REPO-ID from the HF cache (see HF section below),
# not from models/. Keep the repo-id here.
SEARCH_EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# Cached product embedding vectors + their id alignment (reused, never re-encoded).
SEARCH_EMBEDDINGS_VECTORS_PATH=results/product_embeddings_minilm.npy
SEARCH_EMBEDDINGS_IDS_PATH=results/product_embeddings_ids.npy
# Optional warm cross-encoder score cache (app runs fine if this file is absent).
SEARCH_CE_CACHE_PATH=results/week5_ce_cache.pkl

# ---- Hugging Face offline ----------------------------------------------------
# CRITICAL: the embedding model (all-MiniLM-L6-v2) is loaded by repo-id and lives
# in the HF cache (~/.cache/huggingface), NOT in the repo's models/ dir.
#
#   Option A (recommended, reproducible): pre-stage the HF cache on the instance
#   (see deployment/scripts/stage_artifacts.sh) and keep offline=true below.
#
#   Option B (simplest on a fresh instance WITH internet): set offline=false for
#   the very first boot so HF downloads the ~88 MB model once, then flip back to
#   true. EC2 has open internet by default, so this works.
SEARCH_HF_HUB_OFFLINE=true
# Raw Hugging Face / transformers offline switches (read by the HF libraries
# directly, not via pydantic). Keep them consistent with SEARCH_HF_HUB_OFFLINE.
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
# If you pre-stage the cache somewhere other than the service user's home, point
# HF_HOME at it explicitly (uncomment and adjust to a path on the instance):
# HF_HOME=/opt/search-ranking/.cache/huggingface

# ---- Logging -----------------------------------------------------------------
SEARCH_LOG_LEVEL=INFO
SEARCH_LOG_TO_FILE=true
SEARCH_LOG_FILE=logs/api.log
# Rotating file handler: max bytes per file and how many rotated files to keep.
SEARCH_LOG_MAX_BYTES=5000000
SEARCH_LOG_BACKUP_COUNT=5
# Set true to emit one-line JSON logs (easier for the CloudWatch agent to parse).
SEARCH_LOG_JSON=true

# ---- Frontend ----------------------------------------------------------------
# Streamlit runs ON the same instance and calls the backend over loopback.
# Do NOT use the public IP here -- keep it internal. The frontend's own listen
# port (8501) is set in search-frontend.service, not here; nginx proxies / to it.
SEARCH_API_URL=http://127.0.0.1:8000

# ---- Intentionally omitted ---------------------------------------------------
# SEARCH_SUPPORTED_METHODS : a JSON list; unsafe/awkward in an EnvironmentFile.
#                            Leave unset to use the built-in default set
#                            (tfidf, bm25, embedding, hybrid, rerank, ltr).
# SEARCH_TESTING           : test-only flag; if true the app skips loading models.
#                            Never set it in production (default false).
