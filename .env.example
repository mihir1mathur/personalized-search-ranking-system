# =============================================================================
# .env.example  --  environment configuration for the Personalized Search
# Ranking System. Copy to `.env` and adjust as needed:
#
#     cp .env.example .env
#
# Every value is OPTIONAL: the app ships with sensible defaults (see
# api/config/settings.py). Nothing here contains secrets or absolute paths, so
# the same file is portable across Windows, Linux, and AWS.
#
# The backend reads any variable prefixed with SEARCH_ (pydantic-settings).
# The frontend reads SEARCH_API_URL to locate the backend.
# =============================================================================

# ---- Backend: service identity & environment --------------------------------
SEARCH_ENVIRONMENT=development          # development | staging | production
SEARCH_APP_VERSION=6.0.0
SEARCH_API_PREFIX=                      # e.g. /api/v1 to mount under a prefix

# ---- Backend: server binding ------------------------------------------------
SEARCH_HOST=127.0.0.1                   # use 0.0.0.0 in containers / on AWS
SEARCH_PORT=8000

# ---- Backend: retrieval / ranking knobs (reuse Week 3-5 defaults) -----------
SEARCH_DEFAULT_TOP_K=10
SEARCH_MAX_TOP_K=100
SEARCH_CANDIDATE_POOL_SIZE=100
SEARCH_CANDIDATE_DEPTH=50
SEARCH_HYBRID_ALPHA=0.4                 # BM25 (keyword) weight
SEARCH_HYBRID_BETA=0.6                  # embedding (semantic) weight
SEARCH_EMBEDDING_BATCH_SIZE=64
SEARCH_CROSS_ENCODER_BATCH_SIZE=32
SEARCH_CROSS_ENCODER_MAX_CHARS=400
SEARCH_DEVICE=cpu                       # cpu | cuda

# ---- Backend: validation limits ---------------------------------------------
SEARCH_MIN_QUERY_LENGTH=1
SEARCH_MAX_QUERY_LENGTH=256

# ---- Backend: query cache ----------------------------------------------------
SEARCH_CACHE_ENABLED=true
SEARCH_CACHE_MAX_SIZE=512
SEARCH_CACHE_TTL_SECONDS=300

# ---- Backend: model / data / cache paths (relative to the repo root) --------
# These default to the committed Week 0-5 artifacts; override only if you move
# them. Relative paths keep the project portable across machines.
SEARCH_DATA_PATH=data/processed/sample_esci_50k.parquet
SEARCH_MODELS_DIR=models
SEARCH_RESULTS_DIR=results
SEARCH_LTR_MODEL_PATH=models/ltr_lightgbm.txt
SEARCH_CROSS_ENCODER_DIR=models/ms-marco-MiniLM-L-6-v2
SEARCH_EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# ---- Backend: Hugging Face offline (this machine's HF CDN is blocked) --------
SEARCH_HF_HUB_OFFLINE=true
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# ---- Backend: logging --------------------------------------------------------
SEARCH_LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL
SEARCH_LOG_TO_FILE=true
SEARCH_LOG_FILE=logs/api.log
SEARCH_LOG_JSON=false                   # true to emit one-line JSON logs (ELK/CloudWatch)

# ---- Frontend ----------------------------------------------------------------
# Where the Streamlit app finds the FastAPI backend. On AWS set this to the
# backend's public URL (e.g. http://<backend-host>:8000 or an ALB DNS name).
SEARCH_API_URL=http://127.0.0.1:8000
